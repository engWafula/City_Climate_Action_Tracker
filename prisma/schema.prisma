generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Sector {
  transport
  energy
  buildings
  waste
  land_use
}

enum ActionStatus {
  planned
  in_progress
  completed
}

model City {
  id                String          @id @default(cuid())
  name              String
  baselineEmissions Int
  targetYear        Int
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  actions           ClimateAction[]
}

model ClimateAction {
  id              String       @id @default(cuid())
  cityId          String
  title           String
  sector          Sector
  annualReduction Int
  status          ActionStatus
  startYear       Int
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  city            City         @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@index([cityId])
  @@index([sector])
  @@index([status])
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash  String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
